{
  "kind": "singleType",
  "collectionName": "homepages",
  "info": {
    "singularName": "homepage",
    "pluralName": "homepages",
    "displayName": "Homepage",
    "description": "Chili Cloud Storage Homepage"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "hero": {
      "type": "component",
      "repeatable": false,
      "component": "homepage.hero"
    },
    "featureHighlights": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.feature-highlight"
    },
    "pricingTeaser": {
      "type": "component",
      "repeatable": false,
      "component": "homepage.cta-block"
    },
    "socialProofHeadline": {
      "type": "string"
    },
    "testimonials": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::testimonial.testimonial"
    },
    "ctaBottom": {
      "type": "component",
      "repeatable": false,
      "component": "homepage.cta-block"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
